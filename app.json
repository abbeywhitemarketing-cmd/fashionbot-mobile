{
  "expo": {
    "name": "Fashion Bot",
    "slug": "fashion-bot",
    "scheme": "fashionbot",
    "owner": "abbeywhite1996",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/Logos/Logo Round.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/Logos/Logo SquareWtext.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF8F5"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fashionbot.app",
      "buildNumber": "2",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/Logos/Logo square.png"
    },
    "plugins": [
      "expo-asset",
      "expo-web-browser",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "iosDisplayInForeground": true
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "5a7c82f6-602a-4bf1-ab98-95d675d36b08"
      }
    }
  }
}
